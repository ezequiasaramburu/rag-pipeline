PORT=3000

# Postgres — set these and use the same values in DATABASE_URL (Docker Compose reads these)
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=sage

# Connection string for the app; use the same user/password/db as above
DATABASE_URL=postgresql://YOUR_USER:YOUR_PASSWORD@localhost:5432/sage
REDIS_URL=redis://localhost:6379

VECTOR_STORE=pgvector
QDRANT_URL=
QDRANT_API_KEY=

EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=nomic-embed-text
OLLAMA_URL=http://localhost:11434
OPENAI_API_KEY=

LLM_PROVIDER=ollama
LLM_MODEL=llama3
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

DEFAULT_TOP_K=20
RERANKED_TOP_K=5
MAX_CHUNK_TOKENS=512
ENABLE_HYDE=false

EVAL_ENABLED=true
EVAL_LLM_PROVIDER=ollama
EVAL_LLM_MODEL=llama3
